# =============================================================================
# Stock Trader - .gitignore
# =============================================================================

# Environment files - NEVER commit secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# uv
.uv/

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Docker
*.pid

# Database migrations (keep versions directory but ignore pyc)
backend/alembic/versions/__pycache__/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Celery
celerybeat-schedule
celerybeat.pid

# Alembic
alembic.ini.local
