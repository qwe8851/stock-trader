# =============================================================================
# Stock Trader - Environment Variables Example
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL + TimescaleDB)
# -----------------------------------------------------------------------------
POSTGRES_USER=trader
POSTGRES_PASSWORD=traderpassword
POSTGRES_DB=stocktrader
DATABASE_URL=postgresql+asyncpg://trader:traderpassword@postgres:5432/stocktrader

# -----------------------------------------------------------------------------
# Cache & Pub/Sub (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Exchange Selection: "binance" or "upbit"
# -----------------------------------------------------------------------------
ACTIVE_EXCHANGE=binance

# -----------------------------------------------------------------------------
# Binance Exchange API
# Leave empty to use public endpoints only (price reading does not require auth)
# Get your API keys at: https://www.binance.com/en/my/settings/api-management
# -----------------------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Use Binance Testnet for development (set to false for real market data)
BINANCE_TESTNET=false

# -----------------------------------------------------------------------------
# Upbit Exchange API (한국 거래소 — KRW 마켓)
# Market data works without keys; order placement requires API keys
# Get your API keys at: https://upbit.com/mypage/open_api_management
# -----------------------------------------------------------------------------
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# -----------------------------------------------------------------------------
# Security - JWT
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-generate-a-strong-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Trading Safety Flags
# LIVE_TRADING_ENABLED must be explicitly set to "true" to allow real trades
# Default: paper trading only
# -----------------------------------------------------------------------------
LIVE_TRADING_ENABLED=false
PAPER_TRADING_MODE=true

# -----------------------------------------------------------------------------
# Sentiment Analysis (Phase 4)
# -----------------------------------------------------------------------------
# NewsAPI - optional, improves news coverage (free tier: 100 req/day)
# Get your key at: https://newsapi.org/register
NEWSAPI_KEY=

# OpenAI API - optional, used for deep sentiment reasoning on extreme signals
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -----------------------------------------------------------------------------
# Frontend (Vite)
# These are prefixed with VITE_ to be exposed to the browser
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
